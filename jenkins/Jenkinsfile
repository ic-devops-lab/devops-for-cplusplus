pipeline {
  agent any

  options {
    // timestamps()
    disableConcurrentBuilds()
  }

  environment {
    PYTHON_VENV = ".venv"
    ARTIFACT_NAME = "echo_server.tar.gz"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Bootstrap Python') {
      steps {
        sh 'chmod +x scripts/*.sh'
        sh './scripts/bootstrap.sh'
      }
    }

    stage('Build') {
      steps {
        sh './scripts/build.sh'
      }
    }

    stage('Unit Tests') {
      steps {
        sh 'ctest --test-dir build --output-on-failure'
      }
    }

    stage('Integration Tests') {
      steps {
        sh '''
          . .venv/bin/activate
          pytest app/tests/integration -q
        '''
      }
    }

    stage('Code Quality') {
      steps {
        sh '''
          set +e

          echo "=== Running cppcheck ==="
          cppcheck --enable=all --inconclusive --quiet app/src app/include 2> cppcheck-report.txt
          CPPCHECK_EXIT=$?

          echo "=== Running clang-format check ==="
          find app/src app/include -type f \\( -name "*.cpp" -o -name "*.hpp" \\) -print0 | \
            xargs -0 clang-format --dry-run --Werror
          CLANG_FORMAT_EXIT=$?

          echo "cppcheck exit code: ${CPPCHECK_EXIT}"
          echo "clang-format exit code: ${CLANG_FORMAT_EXIT}"

          if [ ${CPPCHECK_EXIT} -ne 0 ] || [ ${CLANG_FORMAT_EXIT} -ne 0 ]; then
            echo "Code quality checks failed"
            exit 1
          fi
        '''
      }
    }

    stage('Package Artifact') {
      steps {
        sh './scripts/package.sh'
      }
    }

    stage('Archive Artifact') {
      steps {
        archiveArtifacts artifacts: 'build/*.tar.gz', fingerprint: true
        archiveArtifacts artifacts: 'cppcheck-report.txt', fingerprint: true, onlyIfSuccessful: false
      }
    }
  }

  post {
    always {
      junit testResults: 'build/test-results/*.xml', allowEmptyResults: true
      cleanWs(deleteDirs: true, notFailBuild: true)
    }
    success {
      echo 'Pipeline completed successfully.'
    }
    failure {
      echo 'Pipeline failed. Check stage logs above.'
    }
  }
}