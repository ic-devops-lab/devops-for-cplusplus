timeout(time: 5, unit: 'MINUTES') {
  node('k8s-agent') {
    def buildStatus = 'SUCCESS'

    try {
      withEnv([
        'PYTHON_VENV=.venv',
        'ARTIFACT_NAME=echo_server.tar.gz'
      ]) {
        stage('Checkout') {
          git url: 'https://github.com/ic-devops-lab/devops-for-cplusplus.git', branch: '004-jenkins-agents'
        }

        stage('Bootstrap Python') {
          sh 'chmod +x scripts/*.sh'
          sh './scripts/bootstrap.sh'
        }

        stage('Build') {
          sh './scripts/build.sh'
        }

        stage('Unit Tests') {
          sh 'ctest --test-dir build --output-on-failure'
        }

        stage('Integration Tests') {
          sh '''
            . .venv/bin/activate
            pytest app/tests/integration -q
          '''
        }

        stage('Code Quality') {
          sh '''
            set -e

            echo "=== Running cppcheck ==="
            cppcheck --enable=all --inconclusive --quiet app/src app/include 2> cppcheck-report.txt || true

            echo "=== Running clang-format check ==="
            find app/src app/include -type f \\( -name "*.cpp" -o -name "*.hpp" \\) -print0 | \
              xargs -0 clang-format --dry-run --Werror
          '''
        }

        stage('SonarQube Analysis') {
          def sonarHome = tool name: 'sonar-scanner'
          withSonarQubeEnv('sonarqube') {
            sh '''
              test -f build/compile_commands.json
              ''' + sonarHome + '''/bin/sonar-scanner
            '''
          }
        }

        stage('Quality Gate') {
          timeout(time: 10, unit: 'MINUTES') {
            waitForQualityGate abortPipeline: true
          }
        }

        stage('Package Artifact') {
          sh './scripts/package.sh'
        }

        stage('Archive Artifact') {
          archiveArtifacts artifacts: 'build/*.tar.gz', fingerprint: true
          archiveArtifacts artifacts: 'cppcheck-report.txt', fingerprint: true, onlyIfSuccessful: false
        }
      }
    } catch (e) {
      buildStatus = 'FAILURE'
      echo 'Pipeline failed. Check stage logs above.'
      throw e
    } finally {
      // Always cleanup
      deleteDir()
    }

    // Post success action
    if (buildStatus == 'SUCCESS') {
      echo 'Pipeline completed successfully.'
    }
  }
}